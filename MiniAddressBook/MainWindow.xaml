<Window x:Class="MiniAddressBook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Address Book" Height="550" Width="900"
        WindowStartupLocation="CenterScreen" >

    <Grid Background="#f4f4f4" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="📒 Mini Address Book"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#333"
                   Margin="10,10,0,10"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- FORM -->
            <Border Grid.Column="0"
                    Margin="10"
                    Background="White"
                    Padding="10"
                    BorderBrush="#ccc"
                    BorderThickness="1"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Add / Edit Contact" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                    <TextBlock Text="First Name:"/>
                    <TextBox x:Name="txtFirstName" Margin="0,5,0,10"/>

                    <TextBlock Text="Last Name:"/>
                    <TextBox x:Name="txtLastName" Margin="0,5,0,10"/>

                    <TextBlock Text="Email:"/>
                    <TextBox x:Name="txtEmail" Margin="0,5,0,10"/>

                    <TextBlock Text="Phone:"/>
                    <TextBox x:Name="txtPhone" Margin="0,5,0,10"/>

                    <TextBlock Text="City:"/>
                    <TextBox x:Name="txtCity" Margin="0,5,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="btnAdd" Content="Add" Width="70" Margin="5"/>
                        <Button x:Name="btnEdit" Content="Edit" Width="70" Margin="5"/>
                        <Button x:Name="btnDelete" Content="Delete" Width="70" Margin="5"/>
                        <Button x:Name="btnSave" Content="Save" Width="70" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- DATAGRID -->
            <StackPanel Grid.Column="1" Margin="10">
                <DockPanel Margin="0,0,0,10">
                    <TextBox x:Name="txtSearch"
                             Width="250"
                             Height="28"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"
                             Text="Search..."/>
                </DockPanel>

                <DataGrid x:Name="dgContacts"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          AlternatingRowBackground="#f9f9f9"
                          HeadersVisibility="Column"
                          BorderBrush="#ccc"
                          BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*"/>
                        <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>