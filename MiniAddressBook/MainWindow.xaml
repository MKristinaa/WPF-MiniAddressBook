<Window x:Class="MiniAddressBook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Address Book"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#f3f6fa">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Border Background="White"
                Padding="15"
                CornerRadius="8"
                BorderBrush="#ddd"
                BorderThickness="1"
                Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📒"
                           FontSize="28"
                           Margin="0 0 10 0"/>
                <StackPanel>
                    <TextBlock Text="Mini Address Book"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#2d3436"/>
                    <TextBlock Text="Manage your contacts easily"
                               Foreground="#636e72"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="3.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#ddd"
                    BorderThickness="1"
                    Padding="20"
                    Margin="0 0 15 0">
                <StackPanel>
                    <TextBlock Text="Contact Details"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 5"/>
                    <TextBlock Text="Click on a contact in the table to edit or delete."
                               Foreground="#888"
                               FontSize="12"
                               Margin="0 0 0 15"/>

                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="First Name" FontWeight="SemiBold"/>
                        <TextBlock Text="*" Foreground="Red" Margin="2,0,0,0"/>
                    </StackPanel>
                    <TextBox Height="30"
                             Margin="0 5 0 12"
                             Padding="5"
                             Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                             Cursor="IBeam"/>

                  
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Last Name" FontWeight="SemiBold"/>
                        <TextBlock Text="*" Foreground="Red" Margin="2,0,0,0"/>
                    </StackPanel>
                    <TextBox Height="30"
                             Margin="0 5 0 12"
                             Padding="5"
                             Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                             Cursor="IBeam"/>

                   
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Email" FontWeight="SemiBold"/>
                        <TextBlock Text="*" Foreground="Red" Margin="2,0,0,0"/>
                    </StackPanel>
                    <TextBox Height="30"
                             Margin="0 5 0 12"
                             Padding="5"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Cursor="IBeam"/>

                  
                    <TextBlock Text="Phone"/>
                    <TextBox Height="30"
                             Margin="0 5 0 12"
                             Padding="5"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Cursor="IBeam"/>

                   
                    <TextBlock Text="City"/>
                    <TextBox Height="30"
                             Margin="0 5 0 20"
                             Padding="5"
                             Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                             Cursor="IBeam"/>

                   
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button Content="Save"
                                Width="80"
                                Height="32"
                                Margin="5"
                                Background="#00b894"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding CanSave}"
                                Cursor="Hand"/>

                        <Button Content="Delete"
                                Width="80"
                                Height="32"
                                Margin="5"
                                Background="#d63031"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding DeleteCommand}"
                                Cursor="Hand"/>

                        <Button Content="Clear"
                                Width="80"
                                Height="32"
                                Margin="5"
                                Background="#0984e3"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding ClearFormCommand}"
                                Cursor="Hand"/>

                    </StackPanel>

                </StackPanel>
            </Border>

          
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#ddd"
                    BorderThickness="1"
                    Padding="15">

                <StackPanel>
                   
                    <DockPanel Margin="0 0 0 10">
                        <TextBlock Text="🔍 Search"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Margin="0 0 10 0"/>
                        <TextBox Width="250"
                                 Height="30"
                                 Padding="5"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Cursor="IBeam"/>
                    </DockPanel>

                  
                    <DataGrid
                        ItemsSource="{Binding Contacts}"
                        SelectedItem="{Binding SelectedContact, Mode=TwoWay}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True"
                        RowHeight="32"
                        AlternatingRowBackground="#f9fbfd"
                        BorderThickness="0"
                        GridLinesVisibility="None"
                        Cursor="Hand">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="First Name"
                                                Binding="{Binding FirstName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Last Name"
                                                Binding="{Binding LastName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Email"
                                                Binding="{Binding Email}"
                                                Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="ToolTip" Value="{Binding Email}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Phone"
                                                Binding="{Binding Phone}"
                                                Width="*"/>
                            <DataGridTextColumn Header="City"
                                                Binding="{Binding City}"
                                                Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>