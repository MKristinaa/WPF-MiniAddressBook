<Window x:Class="MiniAddressBook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Address Book" Height="550" Width="900"
        WindowStartupLocation="CenterScreen" >

    <Grid Background="#f4f4f4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="📒 Mini Address Book"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#333"
                   Margin="10,10,0,10"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- FORM -->
            <Border Grid.Column="0"
                    Margin="10"
                    Background="White"
                    Padding="10"
                    BorderBrush="#ccc"
                    BorderThickness="1"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Add / Edit Contact" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                    <TextBlock Text="First Name:"/>
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

                    <TextBlock Text="Last Name:"/>
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

                    <TextBlock Text="Email:"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

                    <TextBlock Text="Phone:"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

                    <TextBlock Text="City:"/>
                    <TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="Add" Width="70" Margin="5" Command="{Binding AddCommand}"/>
                        <Button Content="Edit" Width="70" Margin="5" Command="{Binding EditCommand}"/>
                        <Button Content="Delete" Width="70" Margin="5" Command="{Binding DeleteCommand}"/>
                        <Button Content="Save" Width="70" Margin="5" Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- DATAGRID -->
            <StackPanel Grid.Column="1" Margin="10">
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="250" Height="28"/>
                </DockPanel>

                <DataGrid x:Name="dgContacts"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          AlternatingRowBackground="#f9f9f9"
                          HeadersVisibility="Column"
                          BorderBrush="#ccc"
                          BorderThickness="1"
                          ItemsSource="{Binding Contacts}"
                          SelectedItem="{Binding SelectedContact, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="*"/>
                        <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>